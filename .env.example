# ── Maverick managed backend env ──────────────────────────────────────────
# Copy to .env.local for local dev; set the same in the Vercel dashboard.

# Upstream provider keys (server-side only — never shipped to the app)
OPENROUTER_API_KEY=sk-or-v1-xxxx          # LLM (and the model catalog)
GROQ_API_KEY=gsk_xxxx                       # STT (Whisper)
DEEPGRAM_API_KEY=                            # STT (optional alt)
OPENAI_API_KEY=sk-xxxx                       # TTS (and/or STT)
ELEVENLABS_API_KEY=                          # TTS (optional)
REPLICATE_API_KEY=                           # Image/Video gen (optional, future)

# Session signing (generate: `openssl rand -base64 48`)
MAVERICK_JWT_SECRET=replace-with-long-random-string
ACCESS_TOKEN_TTL_SECONDS=3600                # 1h
REFRESH_TOKEN_TTL_SECONDS=5184000            # 60d

# Sign in with Apple — native iOS sign-in uses the app bundle id as the token audience
APPLE_AUDIENCE=com.maverick.maverickchat

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx

# Upstash Redis (quota / rate limit)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# Quota
DAILY_MESSAGE_LIMIT=50                        # free-tier default; entitlements row can override

# App Attest (set true before public launch)
APP_ATTEST_REQUIRED=false

# Tinybird metering (optional)
TINYBIRD_TOKEN=
TINYBIRD_EVENTS_URL=https://api.tinybird.co/v0/events?name=maverick_usage
